# Security & CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173/

# API Environment Variables
DATABASE_URL=postgresql://user:password@host/name
PORT=3000
# API Keys for AI and Internal Communication
INTERNAL_API_KEY=your_secret_internal_key_here # Shared with game-server (x-internal-key header)
GEMINI_API_KEY=your_gemini_api_key_here
LOG_LEVEL=info
