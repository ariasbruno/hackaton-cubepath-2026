{
  "name": "el-impostor",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:kitty": "chmod +x scripts/dev/start-dev.sh && ./scripts/dev/start-dev.sh",
    "dev:host": "chmod +x scripts/dev/start-dev-host.sh && ./scripts/dev/start-dev-host.sh"
  },
  "devDependencies": {
    "turbo": "2.9.1"
  },
  "dependencies": {
    "@eslint/plugin-kit": "0.6.1",
    "brace-expansion": "5.0.5",
    "hono": "4.12.9",
    "picomatch": "4.0.4"
  }
}