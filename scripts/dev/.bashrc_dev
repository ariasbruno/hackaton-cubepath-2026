# 1. Cargamos configuración normal
[[ -f ~/.bashrc ]] && source ~/.bashrc

# 2. Aseguramos que Bun esté en el PATH (por si el .bashrc no lo cargó)
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# 3. Feedback visual
echo -e "\e[1;34m>>> Iniciando entorno DEV en: \e[1;32m$(pwd)\e[0m"

# 4. Ejecutar
if command -v bun &> /dev/null; then
    bun run dev
else
    echo -e "\e[1;31mError: No se encontró 'bun'. Por favor, instálalo o revisa tu PATH.\e[0m"
fi